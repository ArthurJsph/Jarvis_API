# Minimal example environment variables for Jarvis Remote Assistant
# Copy this file to .env and edit values before running the server.

# Security
API_KEY=replace_me_with_a_strong_api_key


# Rate limiting (per API key)
RATE_LIMIT_REQUESTS=60
RATE_LIMIT_PERIOD=60

# Server
HOST=0.0.0.0
PORT=8000

# CORS origins (comma-separated or *)
CORS_ORIGINS=*
